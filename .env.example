# Garap environment variables.
# Copy this file to `.env` and fill in real values. Only EXPO_PUBLIC_* vars are
# embedded in the client bundle (Expo convention) — never put server secrets here.

# Supabase (Authentication + Data Sync agents)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# CoinGecko (Revenue Calculation agent). Free tier base URL by default.
EXPO_PUBLIC_COINGECKO_API_URL=https://api.coingecko.com/api/v3
# Optional demo-tier API key (raises the anonymous rate limit).
EXPO_PUBLIC_COINGECKO_API_KEY=
