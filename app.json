{
  "expo": {
    "name": "Garap",
    "slug": "garap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "garap",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCalendarsUsageDescription": "Garap syncs your bounty deadlines to your calendar.",
        "NSRemindersUsageDescription": "Garap creates reminders for upcoming bounty deadlines."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F0F1E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "RECEIVE_BOOT_COMPLETED",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ],
      "package": "com.garap.app"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F0F1E",
          "dark": {
            "backgroundColor": "#0F0F1E"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-calendar",
        {
          "calendarPermission": "Garap syncs your bounty deadlines to your calendar."
        }
      ],
      "expo-notifications",
      "expo-secure-store",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ed2e1200-4369-4f37-bd0e-75de4ed8d85c"
      }
    }
  }
}
